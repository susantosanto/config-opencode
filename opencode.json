{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "description": "[Pembangun] Build agent - implementasi kode",
      "maxTokens": 30000,
      "mode": "primary",
      "model": "opencode/big-pickle",
      "temperature": 0.2,
      "tools": {
        "bash": true,
        "edit": true,
        "glob": true,
        "grep": true,
        "read": true,
        "task": true,
        "write": true
      }
    },
    "council": {
      "description": "[Musyawarah] Council agent - multi-LLM consensus",
      "maxTokens": 20000,
      "mode": "primary",
      "model": "opencode/big-pickle",
      "temperature": 0.5,
      "tools": {
        "read": true,
        "task": true,
        "write": true
      }
    },
    "orchestrator": {
      "description": "[Delegator] Multi-agent orchestrator - analyze task dan delegasikan ke specialist",
      "maxTokens": 25000,
      "mode": "primary",
      "model": "opencode/big-pickle",
      "permission": {
        "task": {
          "*": "deny"
        }
      },
      "temperature": 0.3,
      "tools": {
        "bash": false,
        "edit": true,
        "glob": false,
        "grep": true,
        "read": true,
        "task": true,
        "write": true
      }
    },
    "prometheus": {
      "description": "[Perencana] 🔥 Prometheus - Strategic planning & work plan generation",
      "maxTokens": 16000,
      "mode": "primary",
      "model": "opencode/big-pickle",
      "temperature": 0.2,
      "tools": {
        "bash": false,
        "edit": false,
        "glob": false,
        "grep": true,
        "read": true,
        "task": true,
        "write": true
      }
    },
    "task": {
      "description": "[Pelaksana] Task agent - background operations (search, analysis)",
      "maxTokens": 8000,
      "mode": "primary",
      "model": "opencode/big-pickle",
      "temperature": 0.2,
      "tools": {
        "grep": true,
        "read": true,
        "task": false,
        "webfetch": true,
        "websearch": true
      }
    },
    "momus": {
      "description": "[Reviewer] 📝 Momus - Plan reviewer. Evaluates plans for clarity, verifiability, completeness",
      "maxTokens": 16000,
      "mode": "primary",
      "model": "opencode/big-pickle",
      "temperature": 0.1,
      "tools": {
        "read": true,
        "grep": true,
        "write": false,
        "edit": false,
        "bash": false,
        "task": true
      }
    },
    "metis": {
      "description": "[Analis] 🧠 Metis - Pre-planning analysis. Identifies hidden intentions, ambiguities, AI failure points.",
      "maxTokens": 16000,
      "mode": "primary",
      "model": "opencode/big-pickle",
      "temperature": 0.3,
      "tools": {
        "read": true,
        "grep": true,
        "write": true,
        "edit": false,
        "bash": false,
        "task": true
      }
    },
    "multimodal": {
      "description": "[Analis Media] 👁️ Multimodal-Looker - Analyzes media files (PDFs, images, diagrams)",
      "maxTokens": 20000,
      "mode": "primary",
      "model": "google/antigravity-gemini-3-flash",
      "temperature": 0.1,
      "tools": {
        "read": true,
        "grep": false,
        "write": false,
        "edit": false,
        "bash": false,
        "task": false
      }
    },
    "hephaestus": {
      "description": "[Pekerja] 🔨 Hephaestus - Autonomous deep worker. Goal-oriented execution, thorough research before action.",
      "maxTokens": 32000,
      "mode": "primary",
      "model": "opencode/big-pickle",
      "temperature": 0.1,
      "tools": {
        "read": true,
        "grep": true,
        "glob": true,
        "write": true,
        "edit": true,
        "bash": true,
        "task": true,
        "webfetch": true,
        "websearch": true
      }
    }
  },
  "autoupdate": false,
  "lsp": true,
  "mcp": {
    "ast-grep": {
      "command": [
        "uv",
        "run",
        "--directory",
        "C:/Users/USER/.config/opencode/ast-grep-mcp",
        "python",
        "main.py"
      ],
      "enabled": true,
      "environment": {
        "PATH": "C:/Users/USER/AppData/Local/Programs/Python/Python313/Scripts;C:/Users/USER/.config/opencode/ast-grep-mcp/bin;${PATH}"
      },
      "type": "local"
    },
    "browser-use": {
      "command": [
        "uvx",
        "--from",
        "browser-use[cli]",
