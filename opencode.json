{
  "$schema": "https://opencode.ai/config.json",
  "model": "qwen-code/coder-model",
  "mode": {
    "primary": {
      "prompt": "{file:C:/Users/USER/.config/opencode/AGENTS.md}"
    }
  },
  "plugin": [
    "superpowers@v5.0.7",
    "file:///C:/Users/USER/.config/opencode/oh-my-opencode-slim",
    "opencode-qwen-cli-auth"
  ],
  "skills": {
    "paths": ["C:/Users/USER/.config/opencode/skills"]
  },
  "permission": {
    "skill": {
      "*": "allow",
      "internal-*": "deny",
      "superpowers-*": "deny",
      "task-workflow": "allow",
      "using-superpowers": "allow"
    }
  },
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": ["playwright-mcp", "--browser", "chromium", "--headless"],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["chrome-devtools-mcp", "--headless"],
      "enabled": true
    },
    "memory": {
      "type": "local",
      "command": [
        "node",
        "C:\\Users\\USER\\AppData\\Roaming\\npm\\node_modules\\@modelcontextprotocol\\server-memory\\dist\\index.js"
      ],
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "node",
        "C:\\Users\\USER\\AppData\\Roaming\\npm\\node_modules\\@modelcontextprotocol\\server-sequential-thinking\\dist\\index.js"
      ],
      "enabled": true
    },
    "fetch": {
      "type": "local",
      "command": ["mcp-fetch-server"],
      "enabled": true
    },
    "git": {
      "type": "local",
      "command": ["git-mcp-server"],
      "enabled": true
    },
    "time": {
      "type": "local",
      "command": ["mcp-time"],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": false
    },
    "excel-control": {
      "type": "local",
      "command": ["excel-mcp-server"],
      "enabled": true
    },
    "excel-mcp": {
      "type": "local",
      "command": [
        "C:\\Users\\USER\\AppData\\Local\\Programs\\Python\\Python313\\python.exe",
        "-m",
        "excel_mcp",
        "stdio"
      ],
      "enabled": true
    },
    "word": {
      "type": "local",
      "command": ["doc-tools-mcp"],
      "enabled": true
    },
    "google-sheets": {
      "type": "local",
      "command": ["google-spreadsheet-mcp"],
      "environment": {
        "GOOGLE_SERVICE_ACCOUNT_KEY_PATH": "C:\\Users\\USER\\.openclaw\\credentials\\google-service-account.json"
      },
      "enabled": true
    },
    "windows-mcp": {
      "type": "local",
      "command": ["uvx", "windows-mcp", "--transport", "stdio"],
      "enabled": true,
      "timeout": 60000
    },
    "windows-desktop-automation": {
      "type": "local",
      "command": [
        "node",
        "C:\\Users\\USER\\mcp-windows-desktop-automation\\dist\\index.js"
      ],
      "enabled": true
    },
    "openclaw": {
      "type": "local",
      "command": ["openclaw-mcp", "--openclaw-url", "http://127.0.0.1:18789"],
      "enabled": true
    },
    "winapp-mcp": {
      "type": "local",
      "command": ["winapp-mcp"],
      "enabled": true
    },
    "shell": {
      "type": "local",
      "command": ["super-shell-mcp"],
      "enabled": true
    },
    "pdf": {
      "type": "local",
      "command": ["uvx", "mcp-pdf"],
      "enabled": true,
      "timeout": 60000
    },
    "superpowers": {
      "type": "local",
      "command": ["superpowers-mcp"],
      "enabled": true
    },
    "vision-mcp-server": {
      "type": "local",
      "command": ["python", "-m", "vision_mcp_server.server"],
      "environment": {
        "GROQ_API_KEY": "${GROQ_API_KEY}"
      },
      "enabled": true
    }
  },
  "agent": {
    "orchestrator": {
      "description": "Multi-agent orchestrator - analyze task dan delegasikan ke specialist",
      "mode": "primary",
      "model": "opencode/minimax-m2.5-free",
      "temperature": 0.3,
      "tools": {
        "task": true,
        "write": true,
        "edit": true,
        "read": true,
        "grep": true,
        "glob": false,
        "bash": false
      },
      "permission": {
        "task": {
          "*": "deny"
        }
      }
    },
    "researcher-dapodik": {
      "description": "Cari data GTK dan Peserta Didik di Dapodik Web Service",
      "mode": "subagent",
      "model": "google/gemini-2.5-flash-lite",
      "temperature": 0.2,
      "max_tokens": 8192,
      "enabled": false,
      "tools": {
        "read": true,
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "coder-dokumen": {
      "description": "Buat surat, laporan, dokumen sekolah",
      "mode": "subagent",
      "model": "opencode/minimax-m2.5-free",
      "temperature": 0.4,
      "max_tokens": 8192,
      "enabled": false,
      "tools": {
        "write": true,
        "edit": true,
        "read": true,
        "bash": false
      }
    },
    "analyzer": {
      "description": "Analisis kompleks, debug, reasoning - gunakan GLM 4.5 Air",
      "mode": "subagent",
      "model": "openrouter/z-ai/glm-4.5-air:free",
      "temperature": 0.5,
      "max_tokens": 16384,
      "enabled": false,
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "read": true
      }
    },
    "validator": {
      "description": "Validasi dokumen sebelum export/print",
      "mode": "subagent",
      "model": "opencode/nemotron-3-super-free",
      "temperature": 0.1,
      "max_tokens": 8192,
      "enabled": false,
      "tools": {
        "read": true,
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "explorer": {
      "description": "Explore project besar, long context analysis",
      "mode": "subagent",
      "model": "opencode/big-pickle",
      "temperature": 0.1,
      "max_tokens": 32768,
      "enabled": false,
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "write": false,
        "edit": false
      }
    },
    "flash-research": {
      "description": "Quick research dan lookup - gunakan Gemini Flash",
      "mode": "subagent",
      "model": "google/gemini-2.5-flash",
      "temperature": 0.3,
      "max_tokens": 8192,
      "enabled": false,
      "tools": {
        "read": true,
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "web-developer": {
      "description": "Web Developer - JavaScript, React, Apps Script, debugging",
      "mode": "subagent",
      "model": "opencode/minimax-m2.5-free",
      "temperature": 0.4,
      "max_tokens": 16384,
      "enabled": false,
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "read": true,
        "glob": true,
        "grep": true
      }
    },
    "ai-learner": {
      "description": "AI Engineering Learner - belajar prompt engineering, agentic AI, MCP",
      "mode": "subagent",
      "model": "opencode/nemotron-3-super-free",
      "temperature": 0.5,
      "max_tokens": 16384,
      "enabled": false,
      "tools": {
        "write": true,
        "read": true,
        "bash": false,
        "edit": false
      }
    },
    "system-checker": {
      "description": "System & Config Checker - cek error Windows, OpenCode config, diagnostics",
      "mode": "subagent",
      "model": "openrouter/z-ai/glm-4.5-air:free",
      "temperature": 0.2,
      "max_tokens": 8192,
      "enabled": false,
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "write": false,
        "edit": false,
        "bash": true
      }
    }
  }
}
