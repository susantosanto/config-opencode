{
  "$schema": "https://opencode.ai/config.json",
  "mode": {
    "primary": {
      "prompt": "{file:./SYSTEM_PROMPT.md}"
    }
  },
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  "skills": {
    "paths": ["C:/Users/USER/Documents/opencode-skills"]
  },
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "C:/Users/USER/Documents"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest", "--config", "C:\\Users\\USER\\.config\\opencode\\playwright-config.json"],
      "enabled": true
    },
    "windows-mcp": {
      "type": "local",
      "command": ["C:\\Users\\USER\\.local\\bin\\uvx.exe", "windows-mcp"],
      "enabled": true
    }
  }
}
